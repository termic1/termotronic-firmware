{
    "chip": "esp32c3",

    "erase": {
        "enabled": true
    },

    "flash": {
        "baud": 921600,
        "mode": "QIO",
        "freq": "40m",
        "size": "4MB"
    },

    "memory": {
        "psram": {
            "supported": false,
            "type": "none",
            "speed": "none",
            "vendor": "none"
        }
    },

    "write_layout": [
        { "address": "0x0",      "file": "bootloader.bin" },
        { "address": "0x8000",   "file": "partitions.bin" },
        { "address": "0xe000",   "file": "boot_app0.bin" },
        { "address": "0x10000",  "file": "firmware.bin" }
    ],

    "reset": {
        "before": "default_reset",
        "after": "hard_reset"
    }
}
